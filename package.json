{
  "name": "fivem-pvp-trainer",
  "version": "1.0.3",
  "description": "FiveM PvP Trainer — Desktop App",
  "main": "electron/main.js",
  "author": "KSKluc4",
  "scripts": {
    "electron": "electron .",
    "dist": "electron-builder",
    "release": "node scripts/release.js"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "build": {
    "appId": "com.ksk.fivempvptrainer",
    "productName": "FiveM PvP Trainer",
    "copyright": "Copyright 2026 KSKluc4",
    "files": [
      "electron/**/*",
      "node_modules/electron-updater/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "FiveM-PvP-Trainer-Setup.exe"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "KSKluc4",
      "repo": "fivem-pvp-trainer",
      "releaseType": "release"
    },
    "directories": {
      "output": "dist/electron-build"
    }
  }
}
