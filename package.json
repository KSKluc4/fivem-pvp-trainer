{
  "name": "fivem-pvp-trainer",
  "version": "2.2.2",
  "description": "FiveM PvP Trainer — Desktop App",
  "main": "electron/main.js",
  "author": "KSKluc4",
  "scripts": {
    "electron": "electron .",
    "dist": "electron-builder",
    "icons": "node scripts/generate-icons.js",
    "release": "node scripts/release.js",
    "test": "node --test electron/*.test.js src/frontend/src/trainer/**/*.test.mjs src/frontend/src/services/*.test.mjs src/frontend/src/locales/*.test.mjs && npm run test:api",
    "test:api": "python -m pytest api/tests -q"
  },
  "devDependencies": {
    "electron": "31.7.7",
    "electron-builder": "24.13.3",
    "png-to-ico": "^3.0.2",
    "sharp": "^0.35.3"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "build": {
    "appId": "com.ksk.fivempvptrainer",
    "productName": "FiveM PvP Trainer",
    "copyright": "Copyright 2026 KSKluc4",
    "files": [
      "electron/**/*",
      "node_modules/electron-updater/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "FiveM-PvP-Trainer-Setup.exe"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "KSKluc4",
      "repo": "fivem-pvp-trainer",
      "releaseType": "release"
    },
    "directories": {
      "output": "dist/electron-build"
    }
  }
}
